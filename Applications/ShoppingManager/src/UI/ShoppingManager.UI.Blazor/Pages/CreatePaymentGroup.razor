@page "/create-payment-group"
@using ShoppingManager.Domain.Model
@using ShoppingManager.UI.Blazor.Services

<PageTitle>Create Payment Group</PageTitle>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Create New Payment Group</h1>
            
            <EditForm Model="@paymentGroupModel" OnValidSubmit="@HandleCreatePaymentGroup">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="groupName" class="form-label">Group Name</label>
                    <InputText id="groupName" class="form-control" @bind-Value="paymentGroupModel.Name" placeholder="Enter group name (e.g., Trip to Paris)" />
                    <ValidationMessage For="@(() => paymentGroupModel.Name)" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Create Group</button>
                    <button type="button" class="btn btn-secondary ms-2" @onclick="GoBack">Cancel</button>
                </div>
            </EditForm>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success mt-3" role="alert">
                    @successMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3" role="alert">
                    @errorMessage
                </div>
            }
        </div>
    </div>
</div>

@code {
    private PaymentGroupModel paymentGroupModel = new();
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = null!;

    [Inject]
    private IPaymentGroupApiClient PaymentGroupApiClient { get; set; } = null!;

    private class PaymentGroupModel
    {
        public string Name { get; set; } = string.Empty;
    }

    private async Task HandleCreatePaymentGroup()
    {
        try
        {
            errorMessage = string.Empty;

            if (string.IsNullOrWhiteSpace(paymentGroupModel.Name))
            {
                errorMessage = "Group name is required.";
                return;
            }

            if (paymentGroupModel.Name.Length < 3)
            {
                errorMessage = "Group name must be at least 3 characters long.";
                return;
            }

            // Call the API to create the payment group
            var request = new CreatePaymentGroupRequest
            {
                Name = paymentGroupModel.Name
            };

            var paymentGroup = await PaymentGroupApiClient.CreatePaymentGroupAsync(request);

            successMessage = $"Payment group '{paymentGroup.Name}' created successfully! Group ID: {paymentGroup.Id}";
            paymentGroupModel = new PaymentGroupModel();

            // Optionally redirect after a delay
            await Task.Delay(1500);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }
}
